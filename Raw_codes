# Task 7: Menu System
while True:
    print("\n--- Student Management System ---")
    print("1. View All Students")
    print("2. Enroll Student")
    print("3. Drop Student")
    print("4. Exit")
    
    choice = input("Enter choice: ")

    # Task 7: View All Students
    if choice == '1':
        if not StudentDatabase._student_list:
            print("No students in database.")
        for s in StudentDatabase._student_list:
            s.view_student_info()

    # Task 7 & 8: Enroll or Drop Student with ID validation
    elif choice == '2' or choice == '3':
        sid = input("Enter Student ID: ")
        # Task 8: Check for Invalid student ID
        target = next((s for s in StudentDatabase._student_list if s.get_id() == sid), None)
        
        if target:
            try:
                if choice == '2':
                    target.enroll_student()
                else:
                    target.drop_student()
            except ValueError as e:
                # Task 8: Handling enrollment/drop logic errors
                print(f"Error: {e}")
        else:
            print("Error: Invalid Student ID.")

    # Task 7: Exit option
    elif choice == '4':
        print("Exiting...")
        break
    else:
        print("Invalid choice. Try again.")
