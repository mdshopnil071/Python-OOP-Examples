# Task 1: Create the StudentDatabase class
class StudentDatabase:
    # Class attribute named student_list
    _student_list = []

    # Class method add_student() to insert Student objects
    @classmethod
    def add_student(cls, student_obj):
        cls._student_list.append(student_obj)


# Task 2: Create the Student class
class Student:
    # Task 3 & 9: Constructor and Data Privacy (__ used for private attributes)
    def __init__(self, student_id, name, department, is_enrolled=False):
        self.__student_id = student_id
        self.__name = name
        self.__department = department
        self.__is_enrolled = is_enrolled
        
        # Task 3: Automatically insert the Student object into student_list
        StudentDatabase.add_student(self)

    # Task 4 & 8: Implement enroll_student() with error handling
    def enroll_student(self):
        if self.__is_enrolled:
            raise ValueError(f"Student {self.__student_id} is already enrolled.")
        self.__is_enrolled = True
        print(f"Student {self.__student_id} enrolled successfully.")

    # Task 5 & 8: Implement drop_student() with error handling
    def drop_student(self):
        if not self.__is_enrolled:
            raise ValueError(f"Student {self.__student_id} is not currently enrolled.")
        self.__is_enrolled = False
        print(f"Student {self.__student_id} dropped successfully.")

    # Task 6: Implement view_student_info() method
    def view_student_info(self):
        status = "Enrolled" if self.__is_enrolled else "Not Enrolled"
        print(f"ID: {self.__student_id} | Name: {self.__name} | Dept: {self.__department} | Status: {status}")

    # Helper method to access private ID for Task 7 & 8
    def get_id(self):
        return self.__student_id


